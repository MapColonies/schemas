{
  "$id": "https://mapcolonies.com/vector/ivsApi/synchronizer/v1",
  "type": "object",
  "title": "vectorStandardSynchronizerSchemaV1",
  "description": "Vector's IVS API schema",
  "allOf": [
    { "$ref": "https://mapcolonies.com/common/boilerplate/v2" },
    {
      "type": "object",
      "required": ["sourceDb", "destinationDb"],
      "properties": {
        "sourceDb": { "$ref": "#/definitions/database" },
        "destinationDb": { "$ref": "#/definitions/database" }
      }
    },
    { "$ref": "#/definitions/schedule" }
  ],
  "definitions": {
    "database": {
      "allOf": [
        { "$ref": "https://mapcolonies.com/common/db/full/v2" },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "x-env-value": "DB_TYPE",
              "default": "postgres"
            }
          }
        }
      ]
    },
    "schedule": {
      "type": "string",
      "description": "The cron timing spec",
      "default": "0 0 * * *",
      "examples": ["*/1 * * * *"],
      "x-env-value": "SYNC_FIELDS_CRON"
    }
  }
}
